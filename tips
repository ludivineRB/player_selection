3️⃣ MPD — Modèle Physique (SQL)

Voici un exemple PostgreSQL / SQLite.

CREATE TABLE equipe (
    id_equipe SERIAL PRIMARY KEY,
    nom_equipe TEXT,
    niveau TEXT,
    categorie TEXT
);

CREATE TABLE joueuse (
    id_joueuse SERIAL PRIMARY KEY,
    nom TEXT,
    prenom TEXT,
    date_naissance DATE,
    poste TEXT,
    taille INT,
    poids INT,
    id_equipe INT REFERENCES equipe(id_equipe)
);

CREATE TABLE match (
    id_match SERIAL PRIMARY KEY,
    date_match DATE,
    lieu TEXT,
    competition TEXT,
    saison TEXT,
    id_equipe_domicile INT REFERENCES equipe(id_equipe),
    id_equipe_exterieur INT REFERENCES equipe(id_equipe),
    score_domicile INT,
    score_exterieur INT
);

CREATE TABLE feuille_match (
    id_feuille SERIAL PRIMARY KEY,
    id_match INT REFERENCES match(id_match),
    pdf_url TEXT,
    date_import TIMESTAMP
);

CREATE TABLE composition_equipe (
    id_compo SERIAL PRIMARY KEY,
    id_match INT REFERENCES match(id_match),
    id_equipe INT REFERENCES equipe(id_equipe),
    id_joueuse INT REFERENCES joueuse(id_joueuse),
    titulaire BOOLEAN,
    poste TEXT
);

CREATE TABLE stat_joueuse_match (
    id_stat SERIAL PRIMARY KEY,
    id_joueuse INT REFERENCES joueuse(id_joueuse),
    id_match INT REFERENCES match(id_match),

    buts INT,
    tirs INT,
    passes INT,
    interceptions INT,
    pertes_balle INT,
    fautes INT,
    temps_jeu INT
);
